# Copie para ".env" e ajuste. No Render, defina essas variáveis no painel do serviço.
# NODE_ENV=production é definido automaticamente pelo Render.

# Segredo usado para assinar os cookies de sessão (gere um valor longo e aleatório).
# SESSION_SECRET=gere_um_valor_longo_e_aleatorio_aqui

# Opcional: ativa o login com Google (deixe vazio para desativar).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sincronização do banco (SQLite) do Render para o seu computador.
# Token compartilhado entre o servidor e o script sync-db.js (obrigatório para o backup).
DB_SYNC_TOKEN=defina_um_token_longo_e_aleatorio_aqui

# (usado apenas pelo script sync-db.js no seu PC) URL do site hospedado no Render.
# SYNC_SERVER=https://seu-site.onrender.com
# SYNC_LOCAL_DIR=db-backup

# === E-MAIL (verificação, troca de e-mail/senha, 2FA, desconexão) ===
# Se não configurar, o servidor salva os e-mails em data/emails/*.html e os exibe
# no console (modo dev). Defina abaixo para envio real em produção.
# SMTP_HOST=smtp.seuprovedor.com
# SMTP_PORT=587
# SMTP_USER=seu-email@dominio.com
# SMTP_PASS=sua-senha-de-app
# MAIL_FROM=The Gods Studio <no-reply@seudominio.com>
